{
  "expo": {
    "name": "TripCraft",
    "slug": "TripCraft",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "tripcraft",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tripcraft.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "TripCraft uses Bluetooth to chat with nearby travelers when offline",
        "NSBluetoothPeripheralUsageDescription": "TripCraft uses Bluetooth to discover nearby travelers"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.tripcraft.app",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-sqlite",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": ["peripheral", "central"]
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://trip-craft-backend.vercel.app/api",
      "firebaseApiKey": "AIzaSyBQF1k6tBRiz79DnZm1fbRpyCjMcAVDbMk",
      "firebaseAuthDomain": "tripcraft-f2e84.firebaseapp.com",
      "firebaseProjectId": "tripcraft-f2e84",
      "firebaseStorageBucket": "tripcraft-f2e84.firebasestorage.app",
      "firebaseMessagingSenderId": "648147915355",
      "firebaseAppId": "1:648147915355:web:4eb742a8e1e7917c79657e",
      "router": {},
      "eas": {
        "projectId": "0a68b4c9-b6fb-4fad-8304-31cbe388b297"
      }
    },
    "owner": "ekanshrajput1607"
  }
}
